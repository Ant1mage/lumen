{
  "compilerOptions": {
    /* 核心版本与语法支持 */
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2024",
      "DOM"
    ],
    "jsx": "react-jsx",
    /* 路径映射：使用相对于根目录的路径 */
    "baseUrl": ".",
    "paths": {
      "@main/*": [
        "src/main/*"
      ],
      "@renderer/*": [
        "src/renderer/*"
      ],
      "@preload/*": [
        "src/preload/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    },
    /* 模块兼容性 */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    /* 严谨的类型检查 (修复之前提到的 null 问题) */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    /* 消除已弃用警告 */
    "ignoreDeprecations": "6.0",
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "release"
  ]
}